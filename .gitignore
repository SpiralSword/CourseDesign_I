# =================================================================
# Maven 编译输出
# =================================================================
target/
*.war
*.ear
*.zip
*.tar.gz
*.rar

# =================================================================
# IntelliJ IDEA 配置文件 (非常重要，防止本地环境冲突)
# =================================================================
.idea/
*.iml
*.iws
*.ipr
out/
gen/

.idea/dataSources/
.idea/dataSources.local.xml
.idea/workspace.xml

# =================================================================
# 操作系统临时文件
# =================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# =================================================================
# 日志与临时文件
# =================================================================
*.log
logs/
temp/
tmp/

# =================================================================
# 核心隐私保护 (根据你的项目截图定制)
# =================================================================
# 忽略数据库连接配置（包含你的用户名和密码）
src/main/resources/db.properties

# 忽略 AI 密钥配置（保护你的 DeepSeek/通义千问 API Key）
src/main/resources/ai-config.properties
src/main/resources/api-keys.properties

# =================================================================
# 文件上传存储路径 (防止把你测试上传的头像、PPT也传上去)
# =================================================================
# 如果你在 webapp 下建了 uploads 文件夹
src/main/webapp/uploads/
uploads/

# =================================================================
# 其他
# =================================================================
*.bak
*.tmp
*.swp